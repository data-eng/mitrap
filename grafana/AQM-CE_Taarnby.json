        {
          "query": "import \"strings\"\n\nfrom(bucket: \"${bucket}\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"nanodust\" and r.installation == \"${Station}\")\n  |> filter(fn: (r) => r._field == \"mode\" or r._field == \"pn\")\n  |> pivot(rowKey: [\"_time\"], columnKey: [\"_field\"], valueColumn: \"_value\")\n  |> filter(fn: (r) => exists r.mode and exists r.pn)\n  |> map(fn: (r) => ({\n        _time: r._time,\n        _value: float(v: r.pn),\n        _field: strings.trim(v: r.mode, cutset: \" \\t\\n\")\n  }))\n  |> group(columns: [\"_field\"])\n\n",
